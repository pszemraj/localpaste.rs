            --text-secondary: #969696;
            --border: #464647;
            --accent: #007acc;
            --accent-hover: #1a85d0;
            --danger: #f14c4c;
            --success: #89d185;
            --warning: #cca700;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'SF Pro Display', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            font-size: 14px;
            line-height: 1.6;
            overflow: hidden;
        }

        #app {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        .sidebar {
            width: 280px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .logo {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 18px;
            font-weight: 600;
            color: var(--accent);
        }

        .logo h1 {
            font-size: 20px;
            font-weight: 600;
            margin: 0;
        }

        .quick-actions {
            padding: 12px;
            display: flex;
            gap: 8px;
        }

        .btn-primary, .btn-secondary, .btn-icon {
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            transition: all 0.2s;
            background: var(--accent);
            color: white;
        }

        .btn-secondary {
            background: var(--bg-hover);
            color: var(--text-primary);
        }

        .btn-icon {
            padding: 6px;
            background: transparent;
            font-size: 16px;
        }

        .btn-icon:hover {
            background: var(--bg-hover);
        }

        .btn-icon.danger:hover {
            background: var(--danger);
        }

        .search-container {
            padding: 0 12px 12px;
        }

        .search-container input {
            width: 100%;
            padding: 8px 12px;
            background: var(--bg-primary);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--text-primary);
            font-size: 13px;
        }

        .editor-header {
            padding: 12px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-secondary);
        }

        .paste-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .editor-container {
            flex: 1;
            position: relative;
            overflow: hidden;
            font-family: 'SF Mono', Monaco, 'Cascadia Code', 'Roboto Mono', Consolas, 'Courier New', monospace;
        }

        #editor {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            width: 100%;
            height: 100%;
            padding: 16px 20px;
            background: transparent;
            border: none;
            outline: none;
            color: transparent;
            caret-color: var(--text-primary);
            font-size: 13px;
            line-height: 1.6;
            resize: none;
            font-family: inherit;
            white-space: pre;
            overflow: auto;
            z-index: 2;
        }

        .highlight-layer {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            padding: 16px 20px;
            font-size: 13px;
            line-height: 1.6;
            white-space: pre;
            overflow: auto;
            pointer-events: none;
            color: var(--text-primary);
            z-index: 1;
        }

        .status-bar {
            padding: 8px 20px;
            background: var(--bg-secondary);
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--text-secondary);
        }

        .tree-view {
            list-style: none;
            padding: 0;
        }

        .folder-item {
            margin-bottom: 2px;
        }

        .folder-header {
            display: flex;
            align-items: center;
            padding: 6px 8px;
            cursor: pointer;
            user-select: none;
            border-radius: 4px;
        }

        .folder-header:hover {
            background: var(--bg-hover);
        }

        .folder-arrow {
            width: 16px;
            transition: transform 0.2s;
            font-size: 10px;
        }

        .folder-arrow.expanded {
            transform: rotate(90deg);
        }

        .folder-content {
            display: none;
            padding-left: 20px;
        }

        .folder-content.expanded {
            display: block;
        }

        .paste-item {
            padding: 6px 12px;
            cursor: pointer;
            border-radius: 4px;
            margin: 2px 0;
        }

        .paste-item:hover {
            background: var(--bg-hover);
        }

        .paste-item.active {
            background: var(--accent);
            color: white;
        }

        .paste-name {
            font-weight: 500;
            font-size: 13px;
        }

        .paste-preview {
            font-size: 11px;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .paste-item.active .paste-preview {
            color: rgba(255, 255, 255, 0.8);
